generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// definir roles
enum Roles {
  ADMIN
  USER
}

// Tabla usuarios
model User {
  id         Int      @id @default(autoincrement()) // id del usuario. este van en auto incremento
  supabaseId String?  @unique
  email      String   @unique // email tiene que ser unico
  // el simbolo de interrogacion es porque como estara el metodo de auth con github puede que no de el nombre
  name       String? // nombre del usuario
  password   String? // contraseña
  avatarUrl  String?
  position   String? // puesto del usuario Sr dev, PM etc
  rol        Roles    @default(USER) // definir el rol del usuario, por defecto es usuario
  createAt   DateTime @default(now()) // registrar la fecha de creacion de la cuenta
}
